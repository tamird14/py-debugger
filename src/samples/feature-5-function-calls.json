  "builderCode": "current_n = -1\nx = 0\n\nblocks = []\n\nmain_panel = Panel()\nmain_panel.position = (1,1)\n\nbackground = Rect(width=V('size'), height=2)\nmain_panel.add(background)\n\n# function_call is a special hook called whenever a traced function is entered.\n# kwargs contains the arguments passed to the function.\ndef function_call(function_name, **kwargs):\n    if function_name != 'fib':\n        return\n        \n    global x\n    # diff: how much smaller is the new n compared to the caller's n.\n    # diff=1 means fib(n-1) was called, diff=2 means fib(n-2) was called.\n    diff = current_n - kwargs['n']\n    print(f'The function {function_name} was called with {kwargs}, and {diff=}')\n\n    if diff == 1:\n        block = Circle(width=1, height=2, position=(0, x)) \n        x += 1\n        blocks.append(block)\n        main_panel.add(block)\n\n    if diff == 2:\n        block = Panel()\n        block.add(\n            Circle(width=2, height=1, position=(0,x)),\n            Circle(width=2, height=1, position=(1,x)),\n        )\n        x += 2\n        blocks.append(block)\n        main_panel.add(block)\n\n# function_exit is called whenever a traced function returns.\ndef function_exit(function_name, ret_value):\n    if function_name != 'fib' or len(blocks) == 0:\n        return\n\n    global x\n    print(f'Existing {function_name}')\n    block = blocks.pop()\n    x -= 2 if isinstance(block, Panel) else 1\n    block.delete()\n\n# update is called after each traced line to keep current_n in sync\ndef update(params, scope):\n    global current_n\n    current_n = params['n']",
  "debuggerCode": "size = 5\nn = size\nset_debug(True)\n\ndef fib(n: int) -> int:\n    if n <= 0:\n        print('Full Board!')\n        return 0\n    if n == 1:\n        a = fib(0)  # always stop at n=0 for visuals\n        return 1 + a\n\n    # either remove 1 and compute the rest:\n    a = fib(n-1)\n    # or remove 2 and compute the rest:\n    b = fib(n-2)\n    # The computation was split into two lines istead of just \n    #       return fib(n-1) + fib(n-2)\n    # so that n is restored to this call's scope before fib(n-2) runs,\n    # giving function_call a chance to see the correct diff=2 step.\n    return a + b\n\nfib(n)",
